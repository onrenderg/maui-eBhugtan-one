<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="eTransfers.MorePage"
             xmlns:views="clr-namespace:eTransfers">

    <NavigationPage.TitleView>
        <views:NavTitleView />
    </NavigationPage.TitleView>

    <Grid RowDefinitions="*,Auto,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Margin="10" Spacing="5" Padding="10,0">

                <!-- App Logo -->
                <Image Source="ic_launcher.png"
                       HorizontalOptions="Center"
                       WidthRequest="130"
                       HeightRequest="80"
                       Margin="0,10,0,0"/>

                <Label Text="eTransfers"
                       FontSize="Large"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"
                       Margin="0,-5,0,0"/>

                <Label Text="v23.0"
                       FontSize="Small"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Gray500}"
                       Margin="0,-5,0,5"/>

                <Label Text="Govt. of Himachal Pradesh"
                       FontSize="17"
                       FontAttributes="Bold"
                       LineBreakMode="WordWrap"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"
                       Margin="5,0,0,10"/>

                <!-- Call -->
                <Frame Margin="0,4" Padding="15" CornerRadius="10" HasShadow="True" BorderColor="{StaticResource Gray200}" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Deptt_Call" NumberOfTapsRequired="1"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="📞" FontSize="20" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="9015222725" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"/>
                        <Label Grid.Column="2" Text="›" FontSize="28" VerticalOptions="Center" TextColor="{StaticResource Primary}"/>
                    </Grid>
                </Frame>

                <!-- Website -->
                <Frame Margin="0,4" Padding="15" CornerRadius="10" HasShadow="True" BorderColor="{StaticResource Gray200}" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="deptt_WebSite" NumberOfTapsRequired="1"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="🌐" FontSize="20" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="https://genpmis.hp.nic.in" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"/>
                        <Label Grid.Column="2" Text="›" FontSize="28" VerticalOptions="Center" TextColor="{StaticResource Primary}"/>
                    </Grid>
                </Frame>

                <!-- Email -->
                <Frame Margin="0,4" Padding="15" CornerRadius="10" HasShadow="True" BorderColor="{StaticResource Gray200}" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Deptt_email" NumberOfTapsRequired="1"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="✉️" FontSize="20" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="hrms-support[at]nic[dot]in" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"/>
                        <Label Grid.Column="2" Text="›" FontSize="28" VerticalOptions="Center" TextColor="{StaticResource Primary}"/>
                    </Grid>
                </Frame>

                <!-- Privacy Policy -->
                <Frame Margin="0,4" Padding="15" CornerRadius="10" HasShadow="True" BorderColor="{StaticResource Gray200}" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="policytapped" NumberOfTapsRequired="1"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="🔒" FontSize="20" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Privacy Policy" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"/>
                        <Label Grid.Column="2" Text="›" FontSize="28" VerticalOptions="Center" TextColor="{StaticResource Primary}"/>
                    </Grid>
                </Frame>

                <!-- Manage Department List Button (only visible when coming from TransfersPage) -->
                <Frame x:Name="ResetFrame" Margin="0,4" Padding="15" CornerRadius="10" HasShadow="True" BorderColor="{StaticResource Gray200}" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}" IsVisible="false">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="btn_reset_Clicked" NumberOfTapsRequired="1"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="⚙️" FontSize="20" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Manage Department List" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"/>
                        <Label Grid.Column="2" Text="›" FontSize="28" VerticalOptions="Center" TextColor="{StaticResource Primary}"/>
                    </Grid>
                </Frame>

                <!-- Designed & Developed by NIC -->
                <Label Text="Designed &amp; Developed by"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Gray500}"
                       Margin="0,20,0,0"/>
                <Label Text="National Informatics Centre (NIC)"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Primary}"
                       Margin="0,2,0,5"/>

                <!-- NIC Logo -->
                <Image Source="ic_niclogo.png"
                       HorizontalOptions="Center"
                       HeightRequest="40"
                       Aspect="AspectFit"
                       Margin="0,5,0,15"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" HeightRequest="55">
            <!-- Home Tab (Inactive) -->
            <Border Grid.Column="0" BackgroundColor="#E0E0E0" StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Tab_Home_Tapped"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                    <Image Source="home_ico.png" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Label Text="Home" FontSize="12" HorizontalOptions="Center" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <!-- More Tab (Active) -->
            <Border Grid.Column="1" BackgroundColor="{StaticResource Primary}" StrokeThickness="0">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                    <Label Text="⋯" FontSize="22" HorizontalOptions="Center" TextColor="White"/>
                    <Label Text="More" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"  StrokeThickness="0" Padding="8,6">
            <Label Text="Center of Competence for Mobile Application Development, National Informatics Centre, Himachal Pradesh."
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
        </Border>

    </Grid>

</ContentPage>
