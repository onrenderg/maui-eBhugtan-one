#!csharp

using System.Net.Http;

public class HitServcies
{

    public string PageFinYear = "2025";
    public  string PageAcountNumber = "55069411800";
    public   async Task<string> GetHit()
    {
        HttpResponseMessage res ;
        var client = new HttpClient();  
        var url = $"https://himkosh.nic.in/ehpoltis/wcfServices/OtherPayment.svc/GetPayeeOtherPayments?payeeCode=IP99-99999&paymentMonth=&paymentYear={PageFinYear}&bankAccNo={PageAcountNumber}";
        Console.WriteLine(url);
        res = await client.GetAsync(url);
        Console.WriteLine(res);
        var rawJson = await res.Content.ReadAsStringAsync();
        if (!string.IsNullOrEmpty(rawJson))
        {
            // Console.WriteLine(rawJson);  
            return rawJson;
        }
        else 
        {
            Console.WriteLine("Error");
        }
        
        return "" ;
    }
}

var histservcies = new HitServcies();
string rawJson = await histservcies.GetHit();

