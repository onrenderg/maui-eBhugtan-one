// 1. Define your Class FIRST (Outside of the logic)
public class PaymentResponse 
{
    [JsonPropertyName("PayeeCode")]
    public string PayeeCode { get; set; }

    [JsonPropertyName("NetAmount")] 
    public string Amount { get; set; }

    [JsonPropertyName("BillID")]
    public string BillID { get; set; }
}

using System.Text.Json;

// Inside your method:
var data = JsonSerializer.Deserialize<PaymentResponse>(rawJson);
Console.WriteLine(data.Amount); // Now you can access properties!

#!csharp

using Newtonsoft.Json.Linq;
using System.Collections.Generic;

// 1. Get your raw JSON from the API
string rawJson = await histservcies.GetHit();

if (!string.IsNullOrEmpty(rawJson))
{
    // 2. Use JObject to "jump" straight to the list without a wrapper class
    var details = JObject.Parse(rawJson);
    var token = details.SelectToken("otherPayments");

    // 3. Convert the JSON list directly into your SQLite 'Payments' model list
    List<Payments> apiPayments = token.ToObject<List<Payments>>();

    // 4. Save them to your Database
    foreach (var p in apiPayments)
    {
        // You can set extra fields not in the API here
        p.AccountNumber = histservcies.PageAcountNumber;
        p.Fin_Year = int.Parse(histservcies.PageFinYear);
        
        database_Payments.AddPayments(p);
    }
}
