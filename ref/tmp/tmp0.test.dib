#!csharp

#r "nuget: Newtonsoft.Json"

#!csharp

using System;
using System.IO;
using System.Security.Cryptography;
using System.Text;
using Newtonsoft.Json; // Use for JSON handling

public class HimkoshEncryptor
{
    private const string EncryptionKey = "Himkosh2015BillServiceAESEncryptDecrypt";
    private static readonly byte[] Salt = new byte[] { 0x49, 0x76, 0x61, 0x6e, 0x20, 0x4d, 0x65, 0x64, 0x76, 0x65, 0x64, 0x65, 0x76 };
    private const int KeySize = 32; // 256 bits
    private const int IvSize = 16;  // 128 bits

    public string Encrypt(string plainText)
    {
        byte[] clearBytes = Encoding.ASCII.GetBytes(plainText);
        
        using (Aes encryptor = Aes.Create())
        {
            // Replicates PBKDF2 / Rfc2898DeriveBytes
            using (Rfc2898DeriveBytes pdb = new Rfc2898DeriveBytes(EncryptionKey, Salt, 1000))
            {
                encryptor.Key = pdb.GetBytes(KeySize);
                encryptor.IV = pdb.GetBytes(IvSize);
                encryptor.Mode = CipherMode.CBC;
                encryptor.Padding = PaddingMode.PKCS7;
            }

            using (MemoryStream ms = new MemoryStream())
            {
                using (CryptoStream cs = new CryptoStream(ms, encryptor.CreateEncryptor(), CryptoStreamMode.Write))
                {
                    cs.Write(clearBytes, 0, clearBytes.Length);
                }
                return Convert.ToBase64String(ms.ToArray());
            }
        }
    }

    public string Decrypt(string cipherText)
    {
        byte[] cipherBytes = Convert.FromBase64String(cipherText);
        
        using (Aes encryptor = Aes.Create())
        {
            using (Rfc2898DeriveBytes pdb = new Rfc2898DeriveBytes(EncryptionKey, Salt, 1000))
            {
                encryptor.Key = pdb.GetBytes(KeySize);
                encryptor.IV = pdb.GetBytes(IvSize);
                encryptor.Mode = CipherMode.CBC;
                encryptor.Padding = PaddingMode.PKCS7;
            }

            using (MemoryStream ms = new MemoryStream())
            {
                using (CryptoStream cs = new CryptoStream(ms, encryptor.CreateDecryptor(), CryptoStreamMode.Write))
                {
                    cs.Write(cipherBytes, 0, cipherBytes.Length);
                }
                return Encoding.ASCII.GetString(ms.ToArray());
            }
        }
    }
}

#!csharp

// --- Usage Example ---

var data = new {
    UserName = "eBhugtan",
    Password = "Himkosh@2025",
    FinYear = "2019",
    AccountNo = "55069411800",
    PayeeName = "san"
};


string jsonString = JsonConvert.SerializeObject(data, Formatting.None);
var encryptor = new HimkoshEncryptor();
string encrypted = encryptor.Encrypt(jsonString);
Console.WriteLine(encrypted);

#!csharp

string rawJson = " ";
string encrypted = encryptor.Decrypt(rawJson);
Console.WriteLine(encrypted);
